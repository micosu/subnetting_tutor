// ************************************************************
rule makeVeri {
    when {
        prob : Problem prob.IPaddressDecimal != null
        && prob.firstUsableIP != null && prob.lastUsableIP != null;
        ie : InterfaceElement (ie.name == prob.ieVerification1DropDown || ie.name == prob.ieVerification2DropDown)
        && ie.value == null;
    }
    then {
        function ipToInt(ip) {
            return ip.split('.').reduce((acc, octet) => (acc << 8) + parseInt(octet), 0) >>> 0;
        }

        // Determine which verification we're solving (1 or 2)
        let sel        = ie.name;
        let isVeri1    = (sel == prob.ieVerification1DropDown);
        let targetIP   = isVeri1 ? verification1: verification2;

        let targetInt  = ipToInt(targetIP);
        let firstInt   = ipToInt(prob.firstUsableIP);
        let lastInt    = ipToInt(prob.lastUsableIP);
        let inRange    = targetInt >= firstInt && targetInt <= lastInt;
        let v          = inRange ? " True" : " False";

        // Hints
        assert(new Hint("An assignable IP address falls within the assignable range of the subnet."));
        assert(new Hint("Check if " + targetIP + " falls within the assignable range " + prob.firstUsableIP + " and " + prob.lastUsableIP));
        assert(new Hint("Please enter: " + v));

        if (checkSAI({selection: sel, action: "UpdateComboBox", input: v})) {
            if (isVeri1) {
                modify(prob, "verification1Dropdown", v);
            } else {
                modify(prob, "verification2Dropdown", v);
            }
            modify(ie, "value", v);
            halt();
        } else {
            backtrack();
        }
    }
}

