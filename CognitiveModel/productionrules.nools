             modify(prob, "IPaddressBinary", ip_binary); 
             modify(ipBinary, "value", ip_binary);
             modify(ipBinary2, "value", ip_binary);
          assert(new TPA(ipBinary.name, "UpdateTextField", ip_binary));
             
          let scaffold = document.getElementById("binary_scaffolding");
        scaffold.style.display = "none";
          let binary2 = document.getElementById("binary_scaffolding_answer");
        binary2.style.display = "none";
          let wrapper = document.getElementById("ip_TPA_binary");
let inp = wrapper.querySelector("input");   // grabs the actual textbox inside

// clear existing feedback styling
inp.classList.remove("CTAT--incorrect");
wrapper.classList.remove("CTAT--incorrect");

    // sometimes CTAT colors a parent wrapper instead:
	           halt();
        }
        else {
          backtrack()  
	     }
      
    }
}

// ************************************************************
function maskToPrefix(mask) {
    // Split into octets
    let octets = mask.split(".");

    let prefixLength = 0;

    for (let octet of octets) {
        let num = parseInt(octet);

        // Convert to binary string
        let binary = num.toString(2).padStart(8, "0");

        // Count number of 1s
        for (let bit of binary) {
            if (bit === "1") {
                prefixLength++;
            }
        }
    }
    // console.log("prefixLength: ", prefixLength);
    return prefixLength;
}

rule findPrefixLength {
    when {
        prob : Problem prob.IPaddressDecimal != null && prob.IPaddressBinary != null && prob.prefixLength == null 
        {IPv4: ipv4, ieprefixLength: sel};
        ie : InterfaceElement ie.name == sel && ie.value == null;
    }
    then {
        let prefixLength = 0;
        // hints
        if (subnet) {
          // prefixLength = maskToPrefix(mask);
          let binaryMask = mask
            .split(".")
            .map(o => parseInt(o).toString(2).padStart(8, "0"))
            .join(".");
          prefixLength = binaryMask.replace(/\./g, "")
            .split("0")[0].length;
          assert(new Hint(
            `The prefix length equals <b>the number of consecutive 1s</b> (representing the network bits) at the beginning of the binary subnet mask. Convert ${mask} into binary.`
          ));
          
          assert(new Hint(
              `The subnet mask ${mask} in binary is ${binaryMask}. Count the <b>number of leading 1s</b>, which represent the network bits.`
          ));
          assert(new Hint ("Please enter: " + prefixLength));
        } else {
          prefixLength = IPv4.split("/")[1];
          assert(new Hint("The prefix length shows how many bits are allocated to the network in " + IPv4));
          assert(new Hint("Look at the value after the '/' in " + IPv4 + ". This is the network's prefix length"));
          assert(new Hint ("Please enter: " + prefixLength));
        }
            // model observable action
	      if (checkSAI({selection: sel, action: "UpdateTextField", input: prefixLength})) {
             modify(prob, "prefixLength", prefixLength);
            if (subnet){
              let subnetMaskBinary = Array.from({ length: 4 }, (_, i) =>
                parseInt("1".repeat(prefixLength).padEnd(32, "0").slice(i * 8, i * 8 + 8), 2).toString(2).padStart(8, "0")).join(".");
              modify(prob, "subnetMaskBinary", subnetMaskBinary);  
            }
	           modify(ie, "value", prefixLength);         
	           halt();
        }
        else {
            backtrack();
	     }
    }
}

