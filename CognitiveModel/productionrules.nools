        sai: StudentValues {input: i};
    }
    then {
      assert(new Hint("Make an attempt and additional support will be provided to you."));
        let ip = IPv4.split("/")[0];
        let ip_binary = ip.split('.').map(octet => (+octet).toString(2).padStart(8, '0')).join('.');
            // model observable action
	      if (checkSAI({selection: ipBinary.name, action: "UpdateTextField", input: ip_binary})) {
             modify(prob, "IPaddressBinary", ip_binary); 
             modify(ipBinary, "value", ip_binary);
	           // halt();
        } else {
          if (i != ""){
            let scaffolds = document.getElementById("binary_scaffolding");
            scaffolds.style.display = "block";
            modify(ipBinary, "value", i);
            assert(new TPA(ipBinary.name, "lock"));
            // sai.selection = "octet1_bit1";
            // assert(new StudentValues("octet1_bit1", "", ""));
            setSuccessOrBugMsg("Not quite. Let's try converting to binary together!");
            // assert(new TPA(`octet1_bit1`, "UpdateTextField", ""));
            }
	     }
      halt();
    }
}

// ************************************************************

rule checkAllOctetBits {
    when {
        prob: Problem prob.IPaddressDecimal != null && prob.IPaddressBinary == null {IPv4: ipv4, IPaddressBinary: ipaddress};
        ipBinary: InterfaceElement ipBinary.name == "ip_TPA_binary" && ipBinary.value != null;  
        ie: InterfaceElement ie.name=~ /^octet[1-4]_bit[1-8]$/ && ie.value == null {name: sel};
        scaffold: BinaryScaffolding scaffold.nextPos == sel;
    }
    then {
        let parts = sel.match(/octet(\d)_bit(\d)/);
        let octetIdx = parseInt(parts[1]) - 1;
        let bitPos   = parseInt(parts[2]);
        let octetNum = parseInt(parts[1]);

        let octets = ipv4.split("/")[0].split(".");
        let octetValue = parseInt(octets[octetIdx]);
        const bitValues = [128, 64, 32, 16, 8, 4, 2, 1];
        let correctBit = (octetValue & bitValues[bitPos - 1]) ? "1" : "0";
        let bitValue = bitValues[bitPos - 1];

        assert(new Hint(
            `For octet ${octetNum} (value: ${octetValue}), determine whether the ${bitValue}s bit should be 0 or 1.`
        ));
        // Determine how much value has already been accounted for
        let sumSoFar = 0;
        
        for (let i = 0; i < bitPos - 1; i++) {
            if (octetValue & bitValues[i]) {
                sumSoFar += bitValues[i];
            }
        }
        
        let remainder = octetValue - sumSoFar;
        if (sumSoFar > 0) {
        assert(new Hint(
            `So far for this octet we have ${sumSoFar}. ` +
            `${octetValue} - ${sumSoFar} = ${remainder}. ` +
            `Is ${remainder} >= ${bitValue}? If yes, enter 1 and subtract ${bitValue} 
                from ${octetValue}. If no, enter 0.`
        ));
        } else {
            assert(new Hint(
                `Start with ${octetValue}. ` +
                `Is ${octetValue} >= ${bitValue}?`
            ));
        }
        assert(new Hint(
            `The ${bitValue}s bit for octet ${octetNum} (${octetValue}) should be: ${correctBit}`
        ));
      
        

        if (checkSAI({ selection: sel, action: "UpdateTextField", input: correctBit })) {
            modify(scaffold, sel, correctBit);
            modify(ie, "value", correctBit);
            let allFilled = true;
            for (let n = 1; n <= 4; n++) {
                for (let b = 1; b <= 8; b++) {
                    let key = `octet${n}_bit${b}`;
                    let val = (key === sel) ? correctBit : scaffold[key];
                    if (val == null) { allFilled = false; break; }
                }
                if (!allFilled) break;
            }
      
            if (allFilled) {
              let secondBinary = document.getElementById("binary_scaffolding_answer");
              secondBinary.style.display = "block";
              modify(scaffold, "all_octets_done", true);
            } else {
              let nextPos = [octetNum,bitPos];
              if (bitPos == 8) {
                nextPos = [nextPos[0] + 1, 1];
              } else {
                nextPos = [nextPos[0], bitPos+1];
              }
              // console.log("NEXT POSITION: ", `octet${nextPos[0]}_bit${nextPos[1]}`);
              modify(scaffold, "nextPos", `octet${nextPos[0]}_bit${nextPos[1]}`);
              // assert(new StudentValues(`octet${nextPos[0]}_bit${nextPos[1]}`, "", ""));
              // assert(new TPA(`octet${nextPos[0]}_bit${nextPos[1]}`, "UpdateTextField", ""));
              }
              halt();
          } else {
              backtrack();
          }
        
    }
}

rule buggy_checkAllOctetBits {
  salience: -2;
  when {
      prob: Problem prob.IPaddressDecimal != null && prob.IPaddressBinary == null {IPv4: ipv4, IPaddressBinary: ipaddress};
      ipBinary: InterfaceElement ipBinary.name == "ip_TPA_binary" && ipBinary.value != null;  
      ie: InterfaceElement ie.name=~ /^octet[1-4]_bit[1-8]$/ && ie.value == null {name: sel};
      scaffold: BinaryScaffolding;
  }
  then {
    let parts = sel.match(/octet(\d)_bit(\d)/);
    let octetIdx = parseInt(parts[1]) - 1;
    let bitPos   = parseInt(parts[2]);
    let octetNum = parseInt(parts[1]);

    let octets = ipv4.split("/")[0].split(".");
    let octetValue = parseInt(octets[octetIdx]);
    const bitValues = [128, 64, 32, 16, 8, 4, 2, 1];
    let correctBit = (octetValue & bitValues[bitPos - 1]) ? "1" : "0";

    let priorBitsFilled = true;
    for (let b = 1; b < bitPos; b++) {
        if (scaffold[`octet${octetNum}_bit${b}`] == null) {
            priorBitsFilled = false;
            break;
        }
    }
    if (checkSAI({selection: sel, action: "UpdateTextField", input: correctBit},null,true)) {
      setSuccessOrBugMsg("Please fill out all previous bits first");
    }
    backtrack(); 
  }
}

