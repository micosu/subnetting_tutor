import("types.nools");

// RULE bootstrap
// Always fired at startup for initialization of working memory

// Binary Scaffolding Helper function
function getBit(octetValue, bitPosition) {
    // bitPosition 1-8, where 1 = 128, 8 = 1
    const bitValues = [128, 64, 32, 16, 8, 4, 2, 1];
    return (parseInt(octetValue) & bitValues[bitPosition - 1]) ? 1 : 0;
}

rule bootstrap {
    when {
        s: Boolean s === false from false;
    }
    then {
        console.log("bootstrap", IPv4);

        // create facts to represent the student interface components

        let Task1Statement = assert(new InterfaceElement("task_1_ipv4"));
        let Task4Statement = assert(new InterfaceElement("cidr_notation_problem_statement"));
      
        let problemStatement = assert(new InterfaceElement("problem_statement"));
        let networkMap = assert(new InterfaceElement("network_map"));
        let first_verification = assert(new InterfaceElement("first_verification_ip"));
        let second_verification = assert(new InterfaceElement("second_verification_ip"));
      
        let IPaddressDecimal = assert(new InterfaceElement("ip_input_decimal"));
        let IPaddressBinary = assert(new InterfaceElement("ip_TPA_binary"));
        let secondIPaddressBinary = assert(new InterfaceElement("second_ip_TPA_binary"));

        for (let n = 1; n <= 4; n++) {
          for (let b = 1; b <= 8; b++) {
            assert(new InterfaceElement(`octet${n}_bit${b}`));
          }
        }
      
        let prefixLength = assert(new InterfaceElement("prefix_length_input"));
      
        let subnetMaskBinary = assert(new InterfaceElement("subnet_mask_input_binary"));
        let subnetMaskDecimal = assert(new InterfaceElement("subnet_mask_TPA_decimal"));

        let firstOrNetworkIPBinary = assert(new InterfaceElement("network_ip_input_binary"));
        let firstOrNetworkIPDecimal = assert(new InterfaceElement("network_ip_TPA_decimal"));

        let lastOrBroadcastIPBinary = assert(new InterfaceElement("broadcast_ip_input_binary"));
        let lastOrBroadcastIPDecimal = assert(new InterfaceElement("broadcast_ip_TPA_decimal"));

        let firstUsableIP = assert(new InterfaceElement("first_usable_ip_input_binary"));
        let lastUsableIP = assert(new InterfaceElement("last_usable_ip_input_binary"));

        let verification1Dropdown = assert(new InterfaceElement("first_verification_option"));
        let verification2Dropdown = assert(new InterfaceElement("second_verification_option"));

        let newCIDR = assert(new InterfaceElement("igk9l"));
        let defaultGateway = assert(new InterfaceElement("default_gateway_input"));


         assert(new Problem("calculate"+IPv4, IPv4, 
                   IPaddressDecimal.name, IPaddressBinary.name,
                   secondIPaddressBinary, prefixLength.name,
                   subnetMaskBinary.name, subnetMaskDecimal.name,
                   firstOrNetworkIPBinary.name, firstOrNetworkIPDecimal.name,
                   lastOrBroadcastIPBinary.name,lastOrBroadcastIPDecimal.name,
                    firstUsableIP.name,lastUsableIP.name,
                    verification1Dropdown.name,verification2Dropdown.name, 
                    defaultGateway.name, newCIDR.name
                  ));

        assert(new BinaryScaffolding({}));

        // write the numberToSquare to the proper student interface component
        assert(new TPA(problemStatement.name, "UpdateTextField", problem_statement));
        
        assert(new TPA(Task4Statement.name, "UpdateTextField", task_4_statement));
        assert(new TPA(networkMap.name, "setImage", network_map_diagram));
        assert(new TPA(first_verification.name, "UpdateTextField", verification1));
        assert(new TPA(second_verification.name, "UpdateTextField", verification2));

        if (subnet) {
          assert(new TPA(Task1Statement.name, "UpdateTextField", `${IPv4} <br>
          Subnet Mask: ${mask}`));
          let subnet_row = document.getElementById("subnet_mask_row");
          subnet_row.style.display = "none";
        } else {
          assert(new TPA(Task1Statement.name, "UpdateTextField", IPv4));
        }
      
        var dialog;

        dialog = $("<div>", {
          id: "dialog-form",
          title: "Network Map"
        }).dialog({
          autoOpen: false,
          height: 500,
          width: 675,
          modal: true,
          resizable: true
        });
        
        dialog.html(`
          <p class="networkMapDialogBox" style="text-align:center;">
            You can move and resize this window
          </p>
          <div id="networkMapImageHolder"></div>
        `);
        
        const holder = document.getElementById("networkMapImageHolder");
        holder.innerHTML = ""; // prevent duplicates
        
        var elem = document.createElement("img");
        elem.classList.add("networkMapImg");       // <-- important
        elem.setAttribute("src", network_map_diagram);
        elem.setAttribute("alt", "Network map diagram");
        holder.appendChild(elem);
        
        // Use your CTAT div if you want, but I'd recommend your real element id:
        let networkMapButton = document.getElementById("network_map"); 
        networkMapButton.addEventListener("click", function () {
          dialog.dialog("option", "modal", false);
          dialog.dialog("open");
        });

        // For Binary scaffolding, replace octets with those of current IP
        let ip = IPv4.split("/")[0].split(".");
        ip.forEach((octet, i) => {
          document.getElementById(`octet_val_${i + 1}`).textContent = octet;
        });
        
 

        setProblemAttribute("use_backtracking", true);
        setProblemAttribute("use_hint_fact", true);
        halt();
    }
}

